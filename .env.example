# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (required for emails, redirects, Stripe return URLs) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (required for billing) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (required for checkout; can use NEXT_PUBLIC_* duplicates if preferred)
STRIPE_PRICE_PATIENT_ESSENTIAL_MONTHLY=
STRIPE_PRICE_PATIENT_ESSENTIAL_ANNUAL=
STRIPE_PRICE_PATIENT_STANDARD_MONTHLY=
STRIPE_PRICE_PATIENT_STANDARD_ANNUAL=
STRIPE_PRICE_SPECIALIST_LISTED_MONTHLY=
STRIPE_PRICE_PATIENT_OVERAGE=

# --- Matching Edge Function (recommended in production) ---
MATCH_INTERNAL_SECRET=

# --- Email (optional; emails skipped if unset) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Error monitoring (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
